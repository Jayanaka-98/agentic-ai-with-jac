# Copy to .env and fill in the key for whichever model you point the examples at.
# The examples bind `glob llm = Model(model_name="openai/gpt-4o-mini")`, which
# uses OPENAI_API_KEY. Swap the model_name in each .jac file to use another.

OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...      # for model_name="anthropic/claude-sonnet-4-6"
# GEMINI_API_KEY=...                # for model_name="gemini/gemini-2.0-flash"
